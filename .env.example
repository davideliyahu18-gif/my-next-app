# Website live feed (required for WhatsApp → site sync)
FEED_API_SECRET=generate-a-long-random-secret

# Upstash Redis (auto-set when Upstash integration is linked on Vercel)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Public site URL for bot configuration:
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Cron security (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-secret

# --- Flight deals bot (TLV round-trip ≤ $50, every 30 min) ---

# אופציה 1 — Travelpayouts (הכי קל, בעברית, בלי Amadeus)
# https://www.travelpayouts.com/developers/api
TRAVELPAYOUTS_TOKEN=

# אופציה 2 — SerpAPI (הרשמה עם Google, 250 חיפושים חינם בחודש)
# https://serpapi.com/users/sign_up
SERPAPI_API_KEY=

# אופציה 3 — Amadeus (אם הצלחת להירשם)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# AMADEUS_API_BASE=https://api.amadeus.com

# אופציה 4 — בדיקה בלי שום הרשמה
# FLIGHT_DEALS_DEMO=true
# FLIGHT_DEALS_MAX_PRICE_USD=50

# WhatsApp — שם הקבוצה (הבוט מוצא אוטומטית) או chatId
WHATSAPP_GROUP_NAME=
WHATSAPP_GROUP_CHAT_ID=

# Green API (אופציונלי ל-Vercel)
GREEN_API_INSTANCE=
GREEN_API_TOKEN=

