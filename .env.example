# Website live feed (required for WhatsApp → site sync)
FEED_API_SECRET=generate-a-long-random-secret

# Upstash Redis (auto-set when Upstash integration is linked on Vercel)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Public site URL for bot configuration:
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Cron security (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-secret

# --- Flight deals bot (TLV round-trip ≤ $50, every 30 min) ---

# אופציה 1 — Travelpayouts (הכי קל, בעברית, בלי Amadeus)
# https://www.travelpayouts.com/developers/api
TRAVELPAYOUTS_TOKEN=

# אופציה 2 — SerpAPI / Google Flights
# https://serpapi.com/users/sign_up
SERPAPI_API_KEY=
# Cache Explore windows (ms). Free plan = 250 searches/month — keep high (6h+).
# SERPAPI_CACHE_MS=21600000
# Season range unused while Thailand-only mode is active
# FLIGHT_DEALS_START_MONTH=7
# FLIGHT_DEALS_END_MONTH=12
# Thailand-only watch: Emirates + Etihad (ISO dates)
# FLIGHT_DEALS_THAILAND_OUTBOUND=2027-02-10
# FLIGHT_DEALS_THAILAND_RETURN=2027-03-10
# FLIGHT_DEALS_THAILAND_AIRPORTS=BKK
# FLIGHT_DEALS_THAILAND_AIRLINES=EK
# FLIGHT_DEALS_THAILAND_OUT_DEP=15:10
# FLIGHT_DEALS_THAILAND_OUT_ARR=07:35
# FLIGHT_DEALS_THAILAND_RETURN_NIGHT=true
# FLIGHT_DEALS_THAILAND_MAX_PRICE_ILS=4500
# FLIGHT_DEALS_THAILAND_PRICE_DROP_ILS=100
# FLIGHT_DEALS_THAILAND_BAG_CANDIDATES=8


# אופציה 3 — Skyscanner (דרך RapidAPI Sky Scrapper)
# 1. הירשם: https://rapidapi.com/
# 2. Subscribe ל: https://rapidapi.com/apiheya/api/sky-scrapper (BASIC חינם)
# 3. העתק X-RapidAPI-Key:
SKYSCANNER_RAPIDAPI_KEY=
# RAPIDAPI_KEY=   # alias optional

# אופציה 4 — Amadeus (אם הצלחת להירשם)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# AMADEUS_API_BASE=https://api.amadeus.com

# אופציה 5 — בדיקה בלי שום הרשמה
