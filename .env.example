# Website live feed (required for WhatsApp → site sync)
FEED_API_SECRET=generate-a-long-random-secret

# Upstash Redis (auto-set when Upstash integration is linked on Vercel)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Public site URL for bot configuration:
# NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
# WEBSITE_FEED_URL=https://your-project.vercel.app/api/feed

# Cron / bot API secrets (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-secret
FIFA_BOT_SECRET=generate-a-long-random-secret

# --- FIFA WhatsApp remote-control bot (LIVE + VIP) ---
# Local Baileys script talks to this URL:
# FIFA_BOT_SITE_URL=http://127.0.0.1:3000
#
# MAIN / LIVE — everything except corners:
# FIFA_WHATSAPP_MAIN_GROUP_NAME=דוד | עדכוני מונדיאל LIVE
# FIFA_WHATSAPP_MAIN_CHAT_ID=
#
# VIP — everything except open-play goals:
# FIFA_WHATSAPP_VIP_GROUP_NAME=דוד VIP עדכוני מונדיאל
# FIFA_WHATSAPP_VIP_CHAT_ID=
#
# FIFA_BOT_ALERTS=true
# FIFA_BOT_REMINDER_MINUTES=30
# FIFA_BOT_POLL_CRON=*/1 * * * *

# Optional: send alerts from Vercel cron without Baileys (Green API)
# GREEN_API_INSTANCE=
# GREEN_API_TOKEN=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

